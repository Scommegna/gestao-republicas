<%= form_with(model: [@republica, resident], class: "needs-validation") do |f| %>
  <% if resident.errors.any? %>
    <div class="alert alert-danger">
      <h6><%= pluralize(resident.errors.count, "erro") %> encontrado(s):</h6>
      <ul class="mb-0">
        <% resident.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nome", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :email, "Email", class: "form-label" %>
    <%= f.email_field :email, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :phone, "Telefone", class: "form-label" %>
    <%= f.text_field :phone, class: "form-control", placeholder: "Ex: 35999991234" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-success" %>
    <%= link_to "Cancelar", republica_residents_path(@republica), class: "btn btn-secondary" %>
  </div>
<% end %>